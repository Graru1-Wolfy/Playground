{
  "name": "playground",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/engine-fast",
    "packages/schema"
  ],
  "scripts": {
    "build:packages": "npm run build -w @playground/engine-fast && npm run build -w @playground/schema",
    "build:web": "npm run build -w @playground/web",
    "dev:web": "npm run dev -w @playground/web",
    "dev:web:android": "npm run dev:host -w @playground/web",
    "android:url": "bash scripts/android-dev-url.sh",
    "preview:web": "npm run preview:host -w @playground/web",
    "build:android": "bash scripts/build-android-apk.sh",
    "android:icons": "node scripts/generate-app-icon.mjs",
    "test": "npm run test -w @playground/engine-fast && npm run test -w @playground/schema"
  }
}
