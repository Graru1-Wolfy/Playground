{
  "name": "@playground/web",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc && vite build",
    "build:capacitor": "VITE_CAPACITOR=true tsc && VITE_CAPACITOR=true vite build",
    "build:electron": "VITE_CAPACITOR=true tsc && VITE_CAPACITOR=true vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "test": "vitest run",
    "electron:pack": "electron-builder --win --config electron-builder.yml",
    "electron:pack:dir": "electron-builder --win --dir --config electron-builder.yml",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "cap:build:android": "cd android && ./gradlew assembleDebug",
    "cap:build:android:release": "cd android && ./gradlew assembleRelease",
    "android:apk": "npm run build:capacitor && npm run cap:sync && npm run cap:build:android",
    "android:apk:release": "npm run build:capacitor && npm run cap:sync && npm run cap:build:android:release"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "@playground/engine-fast": "*",
    "@playground/schema": "*"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^22.10.0",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9"
  }
}
