{
  "name": "@playground/web",
  "version": "1.0.21",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc && vite build",
    "build:native": "node scripts/build-native-web.mjs",
    "dist:win": "npm run build:native && electron-builder --win --config electron-builder.yml",
    "android:sync": "npm run build:native && cap sync android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "preview": "vite preview",
    "preview:host": "vite preview --host"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@playground/engine-fast": "*",
    "@playground/schema": "*"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^22.10.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
